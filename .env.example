# Database — local SQLite (default)
IBKR_DB_PATH=~/.ibkr-options-analyzer/data.db

# Database — Turso/libSQL (production, takes precedence over DB_PATH)
IBKR_DB_URL=  # e.g. libsql://my-db-my-org.turso.io
IBKR_DB_AUTH_TOKEN=

# HTTP Client
IBKR_HTTP_TIMEOUT=30
IBKR_HTTP_MAX_RETRIES=5
IBKR_HTTP_RETRY_DELAY_MS=2000

# Flex Polling
IBKR_FLEX_POLL_INTERVAL=5
IBKR_FLEX_MAX_POLL_DURATION=300

# Logging
IBKR_LOG_LEVEL=INFO

# Price Fetching (optional)
ALPHAVANTAGE_API_KEY=

# Authentication (leave GOOGLE_CLIENT_ID empty to disable auth)
IBKR_GOOGLE_CLIENT_ID=
IBKR_GOOGLE_CLIENT_SECRET=
IBKR_OAUTH_REDIRECT_URL=http://localhost:8001/auth/callback
IBKR_SESSION_SECRET=
IBKR_ALLOWED_EMAILS=        # comma-separated allowlist, empty = any Google account
IBKR_INTERNAL_API_KEY=      # auto-generated if empty
